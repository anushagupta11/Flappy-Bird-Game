rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
